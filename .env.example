# AdKan — local environment template.
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.
# Rule 1 reminder: anything with >= 40 contiguous base64-ish characters is radioactive
# and will be blocked by the pre-edit-secret-scan hook.

# ---------- Supabase (EU Frankfurt project) ----------
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY_FROM_SUPABASE_DASHBOARD
# SERVICE_ROLE_KEY: SERVER-ONLY — never exposed to iOS client, never committed, used only
# in Supabase Edge Functions via secrets. Kept here as a placeholder so the .env template
# documents every expected key.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY_RADIOACTIVE_SERVER_ONLY

# ---------- PostHog (EU region, analytics) ----------
POSTHOG_PROJECT_KEY=REPLACE_WITH_POSTHOG_PROJECT_KEY
POSTHOG_HOST=https://eu.i.posthog.com

# ---------- Sentry (iOS crash reporting) ----------
SENTRY_DSN=REPLACE_WITH_SENTRY_IOS_DSN
SENTRY_AUTH_TOKEN=REPLACE_WITH_SENTRY_AUTH_TOKEN_FOR_DSYM_UPLOAD

# ---------- APNs (server-side only; stored in Supabase secrets, NOT on disk) ----------
# These are listed for documentation; the actual values live in Supabase secrets manager.
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YYYYYYYYYY
# APNS_AUTH_KEY_P8_CONTENTS=(contents of AuthKey_XXXXXXXXXX.p8 — never on disk in this repo)
# APNS_TOPIC=com.taltalhayun.adkan
# APNS_ENVIRONMENT=production  # or "sandbox" for TestFlight

# ---------- Mac bridge (DEFERRED — founder has not connected Mac yet) ----------
# When the Mac is online, fill these in config/mac-bridge.json (separate file, also gitignored).
# Leaving them here as .env-level documentation only.
# SSH_HOST=mac
# SSH_USER=REPLACE_WITH_MAC_USERNAME
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_adkan_ed25519

# ---------- Apple Developer ----------
APPLE_ID=REPLACE_WITH_APPLE_ID_EMAIL
# App-specific password for notarytool / fastlane — generated at appleid.apple.com
# APP_SPECIFIC_PASSWORD=REPLACE_WITH_APP_SPECIFIC_PASSWORD
APPLE_TEAM_ID=TBD_APPLE_TEAM_ID_FOUNDER_ACTION

# ---------- Feature flags (non-secret; here for discoverability) ----------
ADKAN_USE_STUB_SCREEN_TIME_PROVIDER=true
# flip to "false" once FamilyControls entitlement is approved AND a physical device
# is available. Controls which ScreenTimeProvider implementation the iOS app injects.
