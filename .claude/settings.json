{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ./scripts/hooks/pre-edit-secret-scan.mjs" },
          { "type": "command", "command": "node ./scripts/hooks/pre-edit-deny-path.mjs" },
          { "type": "command", "command": "node ./scripts/hooks/pre-edit-skill-declaration.mjs" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node ./scripts/hooks/pre-ssh-check.mjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ./scripts/hooks/post-edit-template-check.mjs" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node ./scripts/hooks/subagent-stop-status-update.mjs" }
        ]
      }
    ]
  }
}
